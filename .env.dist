# Environment variables used across the cluster configuration.
# Copy this file to .env, fill in the values, and source it before running commands:
#
#   cp .env.dist .env
#   source .env

# -----------------------------------------------------------------------------
# Talos (01.talos)
# Static IP of the Talos control plane node.
# Used in: talosctl -n / -e flags throughout setup and maintenance commands.
# -----------------------------------------------------------------------------
TALOSIP=

# -----------------------------------------------------------------------------
# Networking
# TRAEFIK_IP: IP assigned by MetalLB to the Traefik ingress controller.
#             Used in: CoreDNS configmap (09.coredns)
#             >kubectl get svc traefik -n ingress-traefik
# METALLB_IP_RANGE: IP range reserved for MetalLB LoadBalancer services.
#             Used in: MetalLB IPAddressPool (03.metallb)
#             Format: 192.168.x.start-192.168.x.end
# -----------------------------------------------------------------------------
TRAEFIK_IP=
METALLB_IP_RANGE=

# -----------------------------------------------------------------------------
# Domains
# DOMAIN: public domain (e.g. example.com). Used in CoreDNS and Ingress configs.
# LOCAL_DOMAIN: optional local/internal domain resolved by CoreDNS only.
# -----------------------------------------------------------------------------
DOMAIN=
LOCAL_DOMAIN=

# -----------------------------------------------------------------------------
# NAS storage (04.storage)
# Applied via envsubst when deploying NAS StorageClasses:
#   kustomize build ./storage | envsubst | kubectl apply -f -
# -----------------------------------------------------------------------------
NAS_IP=        # e.g. 192.168.1.100
NAS_SHARE_MUSIC=     # e.g. media

# -----------------------------------------------------------------------------
# cert-manager / Let's Encrypt (10.cert-manager)
# CFTOK: Cloudflare API token with DNS edit permissions.
# LETSENCRYPT_EMAIL: email used for the ACME account registration.
# -----------------------------------------------------------------------------
CFTOK=
LETSENCRYPT_EMAIL=
