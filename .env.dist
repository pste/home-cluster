# Environment variables used across the cluster configuration.
# Copy this file to .env, fill in the values, and source it before running commands:
#
#   cp .env.dist .env
#   set -a; source .env; set +a
#
# Using `set -a` ensures all variables are exported to subprocesses (e.g. envsubst).

# -----------------------------------------------------------------------------
# Talos (01.talos)
# Static IP of the Talos control plane node.
# Used in: talosctl -n / -e flags throughout setup and maintenance commands.
# -----------------------------------------------------------------------------
TALOSIP=

# -----------------------------------------------------------------------------
# Networking
# TRAEFIK_IP: Traefik's in-cluster ClusterIP. Reachable only from inside the
#             cluster and from Tailscale clients (which route the Service CIDR).
#             Used in: CoreDNS configmap (09.coredns)
#             >kubectl get svc traefik -n ingress-traefik   (CLUSTER-IP column)
# TRAEFIK_EXT_IP: Traefik's MetalLB external IP (LAN-routable). LAN clients can
#             only reach Traefik here, NOT via the ClusterIP.
#             Used in: Pi-hole dnsmasq wildcard (11.pihole)
#             >kubectl get svc traefik -n ingress-traefik   (EXTERNAL-IP column)
# METALLB_IP_RANGE: IP range reserved for MetalLB LoadBalancer services.
#             Used in: MetalLB IPAddressPool (03.metallb)
#             Format: 192.168.x.start-192.168.x.end
# -----------------------------------------------------------------------------
TRAEFIK_IP=10.x.x.x
TRAEFIK_EXT_IP=192.168.x.x
METALLB_IP_RANGE=

# -----------------------------------------------------------------------------
# Domains
# DOMAIN: public domain (e.g. example.com). Used in CoreDNS and Ingress configs.
#         Resolved internally to Traefik via CoreDNS split DNS (09.coredns).
# -----------------------------------------------------------------------------
DOMAIN=

# -----------------------------------------------------------------------------
# NAS storage (04.storage)
# Applied via envsubst when deploying NAS StorageClasses:
#   kubectl kustomize ./storage | envsubst | kubectl apply -f -
# -----------------------------------------------------------------------------
NAS_IP=        # e.g. 192.168.1.100
NAS_SHARE_MUSIC=     # e.g. media
NAS_SHARE_PHOTOS=    # e.g. photos

# -----------------------------------------------------------------------------
# Tailscale (07.tailscale)
# TS_AUTHKEY: auth key generated in the Tailscale admin console.
#             Used in: tailscale-auth Secret (07.tailscale). After the first
#             join the pod keeps its identity in the tailscale-state Secret,
#             so an expired key here is not a problem.
# -----------------------------------------------------------------------------
TS_AUTHKEY=    # e.g. tskey-auth-XXXXXXXXX

# -----------------------------------------------------------------------------
# Pi-hole (11.pihole)
# PIHOLE_IP: fixed LAN IP assigned by MetalLB to the Pi-hole DNS service.
#            Must be inside METALLB_IP_RANGE. Clients/router point to this IP.
#            Used in: Pi-hole Service annotation (11.pihole)
# PIHOLE_WEBPASSWORD: admin web UI password.
#            Used in: pihole-webpassword Secret (11.pihole)
# -----------------------------------------------------------------------------
PIHOLE_IP=     # e.g. 192.168.1.53
PIHOLE_WEBPASSWORD=

# -----------------------------------------------------------------------------
# cert-manager / Let's Encrypt (10.cert-manager)
# CFTOK: Cloudflare API token with DNS edit permissions.
# LETSENCRYPT_EMAIL: email used for the ACME account registration.
# -----------------------------------------------------------------------------
CFTOK=
LETSENCRYPT_EMAIL=
